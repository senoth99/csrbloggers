generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  login              String   @unique
  passwordHash       String
  role               String
  displayName        String?
  employeeId         String?
  completedTaskKeys  String   @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PanelSnapshot {
  id        Int      @id @default(1)
  data      Json
  revision  Int      @default(0)
  updatedAt DateTime @updatedAt
}

model LoginAttempt {
  key       String   @id
  count     Int      @default(1)
  windowEnd DateTime
}
